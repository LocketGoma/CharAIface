# CharAIface local backend server
# Default port 10420 is derived from "Locketgoma":
# "Locket" ASCII sum = 610, "goma" ASCII sum = 420
# 610420 -> 10420, bye bye first number.
APP_HOST=127.0.0.1
APP_PORT=10420

# Resource paths
RESOURCE_DIR=./resources
CHARACTER_DIR=./resources/characters
THEME_DIR=./resources/themes
LOCALE_DIR=./resources/locales
MODEL_REGISTRY_PATH=./resources/models/recommended_models.json

# Local SQLite database path
DATABASE_URL=sqlite:///./resources/data/app.db

# Local AI models
LOCAL_MODEL=llama3.2:1b
STYLE_MODEL=llama3.2:1b

# Cloud AI model
CLOUD_MODEL=openai/gpt-5.1

# Cloud provider API keys
# Fill these only in your local .env file.
# Do not commit .env to Git.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=